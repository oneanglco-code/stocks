# Copy these keys into your Streamlit Cloud app secrets (Settings → Secrets),
# or into a local .streamlit/secrets.toml (never commit the real file).
#
# For Gmail: use an App Password (Google Account → Security → 2-Step
# Verification → App passwords), not your normal password.

[smtp]
server = "smtp.gmail.com"
port = 465
user = "your.address@gmail.com"
password = "your-app-password"
sender = "your.address@gmail.com"
